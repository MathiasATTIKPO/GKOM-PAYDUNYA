<%- include('../partials/css') %>


<div class="form-container">
  <h2>Créer un compte</h2>

  <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
    <div class="error-messages">
      <ul>
        <% errors.forEach(error => { %>
          <li><%= error %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <form method="POST" action="/auth/register">
    <input type="text" name="fullname" placeholder="Nom complet" required value="<%= fullname || '' %>" />
    <input type="tel" name="phone" placeholder="Numéro de téléphone" required value="<%= phone || '' %>" />
    <input type="email" name="email" placeholder="Email" required value="<%= email || '' %>" />
    <input type="password" name="password" placeholder="Mot de passe" required />
    <button type="submit">S'inscrire</button>
  </form>
  <p>Déjà un compte ? <a href="/auth/login">Se connecter</a></p>
</div>


<%- include('../partials/footer') %>
<script src="/js/validation.js"></script>
