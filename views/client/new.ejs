<%- include('../partials/header') %>

<button onclick="openModal()">Acheter cet article</button>

<div id="paymentModal" class="modal">
  <div class="modal-content">
    <span class="close" onclick="closeModal()">&times;</span>
    <h2>Achat : <%= article.name %></h2>
    <p>Prix unitaire : <%= article.price %> F CFA</p>
    <p>Quantité disponible (scrapée) : <strong><%= article.stock %></strong></p>

    <form method="POST" action="/order/new">
      <input type="hidden" name="articleId" value="<%= article._id %>" />

      <!-- Quantité à acheter -->
      <label for="quantity">Quantité à acheter :</label>
      <input 
        type="number" 
        id="quantity" 
        name="quantity" 
        min="1" 
        max="<%= article.stock %>" 
        placeholder="1" 
        required 
      />

      <!-- Sélection du mode de paiement -->
      <label for="payment_mode">Mode de paiement :</label>
      <select id="payment_mode" name="payment_mode" required>
        <option value="">-- Choisir --</option>
        <option value="flooz">Flooz</option>
        <option value="mix-by-yas">Mix By Yas</option>
      </select>

      <!-- Numéro de téléphone -->
      <label for="phone">Numéro Mobile Money (8 chiffres) :</label>
      <input 
        type="text" 
        id="phone" 
        name="phone" 
        
        placeholder="Ex: 90123456" 
        required 
      />

      <button type="submit">Payer maintenant</button>
    </form>
  </div>
</div>

<script>
  function openModal() {
    document.getElementById('paymentModal').style.display = 'block';
  }

  function closeModal() {
    document.getElementById('paymentModal').style.display = 'none';
  }

  window.onclick = function (event) {
    const modal = document.getElementById('paymentModal');
    if (event.target == modal) {
      modal.style.display = 'none';
    }
  };
</script>

<%- include('../partials/footer') %>
